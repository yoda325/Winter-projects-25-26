    "## Defining the Graph Convolutional Network\n",
    "\n",
    "The Graph Convolutional Network captures structural relationships in the transaction graph. The model contains two graph convolution layers.\n",
    "\n",
    "The first layer transforms the input node features into hidden representations.\n",
    "The second layer produces the final outputs used to classify transactions as licit or illicit.\n",
    "\n",
    "During training, nodes update their representations by aggregating information from neighboring nodes."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "id": "fb50fbb1",
   "metadata": {},
   "outputs": [],
   "source": [
    "class GCN(torch.nn.Module):\n",
    "\n",
    "    def __init__(self,in_channels,hidden,out_channels):\n",
    "        super().__init__()\n",
    "\n",
    "        self.conv1=GCNConv(in_channels,hidden)\n",
    "        self.conv2=GCNConv(hidden,out_channels)\n",
    "\n",
    "    def forward(self,data):\n",
    "\n",
    "        x,edge_index=data.x,data.edge_index\n",
    "\n",
    "        x=self.conv1(x,edge_index)\n",
    "        x=F.relu(x)\n",
    "\n",
    "        x=self.conv2(x,edge_index)\n",
    "\n",
    "        return x"
   ]
  },
